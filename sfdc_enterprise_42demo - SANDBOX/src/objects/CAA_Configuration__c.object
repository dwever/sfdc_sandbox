    </actionOverrides>
    <actionOverrides>
        <actionName>View</actionName>
        <type>Default</type>
    </actionOverrides>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <enableActivities>false</enableActivities>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableReports>false</enableReports>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>true</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>Uncheck to ignore this CAA configuration</inlineHelpText>
        <label>Active</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Dedupe_Field_Name__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>The API name of the field (in target object) used to prevent duplicates. This field must be unique in the target object! Also, the type of the field has to be Text, Lookup or Email. No de-duplication if left empty.</inlineHelpText>
        <label>Dedupe Field Name</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Events__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>Which event(s) should trigger the copy? Make sure to fill this one in, or nothing will happen</inlineHelpText>
        <label>Events</label>
        <picklist>
            <picklistValues>
                <fullName>Insert</fullName>
                <default>true</default>
            </picklistValues>
            <picklistValues>
                <fullName>Update</fullName>
                <default>false</default>
            </picklistValues>
            <picklistValues>
                <fullName>Undelete</fullName>
                <default>false</default>
            </picklistValues>
            <sorted>false</sorted>
        </picklist>
        <trackTrending>false</trackTrending>
        <type>MultiselectPicklist</type>
        <visibleLines>4</visibleLines>
    </fields>
    <fields>
        <fullName>Formula_Field_Name__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>[Optional] The API name of the Formula field on the source object that will be evaluated in the triggered records. This Formula Field must be of type text and return &quot;1&quot;, in order for the record to be copied. 

E.g. IF(CONTAINS(Name , &apos;YES&apos;), &apos;1&apos;,&apos;0&apos;)</inlineHelpText>
        <label>Formula Field Name</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Source_Object__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>Use the API name of the object you&apos;re copying from</inlineHelpText>
        <label>Source Object</label>
        <length>100</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Target_Object__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>Use API name of the object you&apos;re copying to</inlineHelpText>
        <label>Target Object</label>
        <length>100</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Test_Target_Normal__c</fullName>
        <description>Do not remove! Used in unit tests</description>
        <externalId>false</externalId>
        <label>Test Target Normal</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Test_Target_Unique__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>Do not remove! Used in unit test</description>
        <externalId>false</externalId>
        <label>Test Target Unique</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <label>CAA Configuration</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Source_Object__c</columns>
        <columns>Target_Object__c</columns>
        <columns>Active__c</columns>
        <columns>Dedupe_Field_Name__c</columns>
        <columns>Events__c</columns>
        <columns>Formula_Field_Name__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>CAAC-{00000}</displayFormat>
        <label>Copy Anything Anywhere Configuration Nr</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>CAA Configurations</pluralLabel>
    <searchLayouts>
        <customTabListAdditionalFields>Source_Object__c</customTabListAdditionalFields>
        <customTabListAdditionalFields>Target_Object__c</customTabListAdditionalFields>
        <customTabListAdditionalFields>Active__c</customTabListAdditionalFields>
        <customTabListAdditionalFields>Dedupe_Field_Name__c</customTabListAdditionalFields>
        <customTabListAdditionalFields>Formula_Field_Name__c</customTabListAdditionalFields>
        <customTabListAdditionalFields>Events__c</customTabListAdditionalFields>
    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
</CustomObject>

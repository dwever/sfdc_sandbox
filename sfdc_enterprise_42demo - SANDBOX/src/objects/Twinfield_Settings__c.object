<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <customSettingsVisibility>Public</customSettingsVisibility>
    <description>Defines settings for the TwinfieldConnector</description>
    <enableEnhancedLookup>false</enableEnhancedLookup>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Booking_Type__c</fullName>
        <defaultValue>&quot;temporary&quot;</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>Type of bookings made in Twinfield:
final or temporary</inlineHelpText>
        <label>Booking Type</label>
        <length>10</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Currency_Iso_Code__c</fullName>
        <defaultValue>&quot;EUR&quot;</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>Currency for bookings</inlineHelpText>
        <label>Currency Iso Code</label>
        <length>10</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Days_Untill_Due_Date__c</fullName>
        <defaultValue>14</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>How many days after the invoice date should payment be made?</inlineHelpText>
        <label>Days Untill Due Date</label>
        <precision>5</precision>
        <required>true</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Default_Daybook__c</fullName>
        <defaultValue>&quot;VRK&quot;</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>In case no daybook is defined, what code should be used?</inlineHelpText>
        <label>Default Daybook</label>
        <length>10</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Default_Ledger_Code__c</fullName>
        <defaultValue>&quot;8015&quot;</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>In case no ledger is defined, what should be used?</inlineHelpText>
        <label>Default Ledger Code</label>
        <length>5</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Ledgercode_Invoiced_In_Advance__c</fullName>
        <defaultValue>&quot;1980&quot;</defaultValue>
        <externalId>false</externalId>
        <label>Ledgercode Invoiced In Advance</label>
        <length>10</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Logon_Endpoint__c</fullName>
        <defaultValue>&quot;https://login.twinfield.com/webservices/session.asmx?wsdl&quot;</defaultValue>
        <description>Endpoint for the Twinfield Logon call.</description>
        <externalId>false</externalId>
        <inlineHelpText>Endpoint for the Twinfield Logon call.</inlineHelpText>
        <label>Logon Endpoint</label>
        <length>255</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Nominal_Code__c</fullName>
        <defaultValue>&quot;1200&quot;</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>Nominal code for total lines</inlineHelpText>
        <label>Nominal Code</label>
        <length>10</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Organization__c</fullName>
        <description>Organisation to login to Twinfield</description>
        <externalId>false</externalId>
        <inlineHelpText>Organisation to login to Twinfield</inlineHelpText>
        <label>Organization</label>
        <length>100</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Password__c</fullName>
        <description>Password to login to Twinfield</description>
        <externalId>false</externalId>
        <inlineHelpText>Password to login to Twinfield</inlineHelpText>
        <label>Password</label>
        <length>50</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ProcessXML_Suffix__c</fullName>
        <defaultValue>&quot;/webservices/processxml.asmx?wsdl&quot;</defaultValue>
        <externalId>false</externalId>
        <label>ProcessXML Suffix</label>
        <length>200</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SOAP_Namespace__c</fullName>
        <defaultValue>&quot;http://schemas.xmlsoap.org/soap/envelope/&quot;</defaultValue>
        <externalId>false</externalId>
        <label>SOAP Namespace</label>
        <length>200</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Timeout__c</fullName>
        <defaultValue>&quot;60000&quot;</defaultValue>
        <description>Timeout in milliseconds</description>
        <externalId>false</externalId>
        <inlineHelpText>Timeout in milliseconds</inlineHelpText>
        <label>Timeout</label>
        <length>8</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Twinfield_Namespace__c</fullName>
        <defaultValue>&quot;http://www.twinfield.com/&quot;</defaultValue>
        <externalId>false</externalId>
        <label>Twinfield Namespace</label>
        <length>200</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Twinfield_Office__c</fullName>
        <defaultValue>&quot;12025&quot;</defaultValue>
        <externalId>false</externalId>
        <inlineHelpText>Office code for your Twinfield instance to make bookings to.</inlineHelpText>
        <label>Twinfield Office</label>
        <length>50</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Username__c</fullName>
        <description>Username to login to Twinfield</description>
        <externalId>false</externalId>
        <inlineHelpText>Username to login to Twinfield</inlineHelpText>
        <label>Username</label>
        <length>50</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Twinfield Settings</label>
</CustomObject>

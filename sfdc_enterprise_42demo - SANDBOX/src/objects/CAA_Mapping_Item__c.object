<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionOverrides>
        <actionName>Accept</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>CancelEdit</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>Clone</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>Delete</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>Edit</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>Follow</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>List</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>New</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>SaveEdit</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>Tab</actionName>
        <type>Default</type>
    </actionOverrides>
    <actionOverrides>
        <actionName>View</actionName>
        <type>Default</type>
    </actionOverrides>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Stored field mappings for Copy Anything Anywhere</description>
    <enableActivities>false</enableActivities>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableReports>false</enableReports>
    <fields>
        <fullName>CAA_Configuration__c</fullName>
        <externalId>false</externalId>
        <label>CAA Configuration</label>
        <referenceTo>CAA_Configuration__c</referenceTo>
        <relationshipLabel>CAA Mapping Items</relationshipLabel>
        <relationshipName>CAA_Mapping_Items</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>true</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Hardcoded_Value__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>Value that will be used to populate the target field. The target field MUST be a text or picklist field and not exceed 255 characters.

Either a Hard Coded Value or a Source Field is mandatory, only one of both may be provided</inlineHelpText>
        <label>Hardcoded Value</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Source_Field__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>API Name of the field in the source object

Either a Hard Coded Value or a Source Field is mandatory, only one of both may be provided</inlineHelpText>
        <label>Source Field</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Target_Field__c</fullName>
        <externalId>false</externalId>
        <inlineHelpText>API Name of the field in the target object</inlineHelpText>
        <label>Target Field</label>
        <length>255</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>CAA Mapping Item</label>
    <nameField>
        <displayFormat>CAAMI-{0000000}</displayFormat>
        <label>CAA Mapping Item Nr</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>CAA Mapping Items</pluralLabel>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Cannot_Use_Id_as_a_Target</fullName>
        <active>true</active>
        <description>ID is not allowed as a target</description>
        <errorConditionFormula>LOWER(Target_Field__c) = &apos;id&apos;</errorConditionFormula>
        <errorMessage>Id cannot be the target field</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Hardcoded_Value_Not_Allowed_On_Dedupe</fullName>
        <active>false</active>
        <errorConditionFormula>AND(
NOT(ISBLANK(Hardcoded_Value__c )),
 CAA_Configuration__r.Dedupe_Field_Name__c = Hardcoded_Value__c 
)</errorConditionFormula>
        <errorDisplayField>Hardcoded_Value__c</errorDisplayField>
        <errorMessage>Deduplication field in target cannot be mapped to a hardcoded value</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Source_Field_Or_Value_Mandatory</fullName>
        <active>true</active>
        <description>Checks if either Source_Field__c or Hardcoded_Value__c is set, and not both</description>
        <errorConditionFormula>OR(
AND(ISBLANK( Hardcoded_Value__c ) , ISBLANK( Source_Field__c )),
AND(NOT(ISBLANK( Hardcoded_Value__c )) , NOT(ISBLANK( Source_Field__c )))
)</errorConditionFormula>
        <errorMessage>You need to provide either a Source Field, or a Hardcoded Value</errorMessage>
    </validationRules>
</CustomObject>
